JWT_AUDIENCE=chat
ENV=development
LOG_LEVEL=info
PORT=8001

MIGRATION_DATABASE_URL=
APP_DATABASE_URL=

JWT_JWKS_URI=http://authentication:8014/.well-known/jwks.json
FRONTEND_URL=http://localhost:5173

# AI assistant inference (OpenAI-compatible chat completions). Required for assistant replies.
INFERENCE_COMPLETIONS_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=
# INFERENCE_TEMPERATURE=1.0

# AI assistant prompts (deployment configuration — bring your own; keep private).
# Omit to use shipped defaults in prompts/. Prefer *_FILE for readable editing:
# AGENT_PRIMING_PROMPT_FILE=/etc/neosofia/chat/agent-priming-prompt.txt
# AGENT_INSTRUCTIONS_FILE=/etc/neosofia/chat/agent-instructions.txt

# User Service — tenant lookup for authorization on cross-user access
USER_SERVICE_BASE_URL=http://user:8018

# Message sender taxonomy (comma-separated). Shipped defaults:
# MESSAGE_SENDER_TYPES=patient,ai_agent,clinician
# INTERVENTION_SENDER_TYPES=clinician
# COMPLETION_USER_SENDER_TYPE=patient
# COMPLETION_ASSISTANT_SENDER_TYPE=ai_agent
